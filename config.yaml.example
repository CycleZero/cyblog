data:
  db:
    host: localhost
    port: 3306
    user: your_db_user
    password: your_db_password
    db_name: cyblog
  minio:
    endpoint: localhost:9000
    accessKey: your_access_key
    secretKey: your_secret_key
    useSSL: false
    bucket: cyblog
  redis:
    host: localhost
    port: 6379
    password: your_redis_password
  nats:
    host: localhost
    port: 4222

server:
  http:
    host: 0.0.0.0
    port: 8000
    pprof:
      enable: false
      port: 6060
      host: 0.0.0.0

llm:
  endpoint: https://api.deepseek.com
  apikey: your_api_key
  model: deepseek-chat

log:
  mode: dev
  level: debug
  dir: ./data/log

app:
  dev_mode: true
  enable_db_debug: false

jwt:
  secret: your_jwt_secret_key
